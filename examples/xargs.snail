#!/usr/bin/env -S snail --xargs -b 'print("xargs start")' -e 'print("xargs done")' -f
# Xargs mode example (process each file as a whole).
# -b and -e flags in the shebang run code before/after the xargs { } block.

# $src is the input path; $text is the full file contents.
print("File:", $src)
print("Size:", len($text), "bytes")
if $text { first_line = $text.split('\n')[0] } else { first_line = "(empty)" }
print("First line:", first_line)
print("---")
